<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Círculo de fondo -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/colorPrimary" />
            <size android:width="72dp" android:height="72dp" />
        </shape>
    </item>
    <!-- Checkmark como stroke -->
    <item
        android:top="18dp"
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp">
        <shape android:shape="oval">
            <stroke android:color="@color/colorOnPrimary" android:width="3dp" />
        </shape>
    </item>
</layer-list>
