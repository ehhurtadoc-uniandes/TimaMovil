<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:paddingHorizontal="32dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lo hiciste!!!"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtítulo 1 -->
    <TextView
        android:id="@+id/tv_subtitle1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Completaste 20 burpees\na las 7:30AM"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtítulo 2 -->
    <TextView
        android:id="@+id/tv_subtitle2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Estas construyendo\ndisciplina"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Card resumen -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F2F2F2"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Reto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reto"
                android:textSize="12sp"
                android:textColor="@color/textSecondary" />
            <TextView
                android:id="@+id/tv_reto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20 burpees"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="16dp" />

            <!-- Hora -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hora"
                android:textSize="12sp"
                android:textColor="@color/textSecondary" />
            <TextView
                android:id="@+id/tv_hora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="07:34 AM"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="16dp" />

            <!-- Racha actual -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Racha actual"
                android:textSize="12sp"
                android:textColor="@color/textSecondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 días consecutivos"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Botón Ver estadísticas (secundario, abajo) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_estadisticas"
        style="@style/TimaButtonSecondary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Ver estadísticas"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Continuar (primario, sobre estadísticas) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_continuar"
        style="@style/TimaButtonPrimary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Continuar"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_estadisticas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
