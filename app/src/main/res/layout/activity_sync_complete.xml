<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:paddingHorizontal="32dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sincronización"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ícono checkmark -->
    <ImageView
        android:id="@+id/iv_check"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_check_circle_filled"
        android:contentDescription="Completado"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38" />

    <!-- Texto completado -->
    <TextView
        android:id="@+id/tv_completado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sincronización completada"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/iv_check"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Ver estadísticas (secundario, abajo) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_estadisticas"
        style="@style/TimaButtonSecondary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Ver estadísticas"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Continuar (primario, sobre estadísticas) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_continuar"
        style="@style/TimaButtonPrimary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Continuar"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_estadisticas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
