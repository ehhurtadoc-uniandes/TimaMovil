<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:paddingHorizontal="32dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tipo de ejercicio"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lista de ejercicios con RadioGroup -->
    <RadioGroup
        android:id="@+id/list_exercises"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Abdominales -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="A"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_avatar" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Abdominales"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginStart="16dp" />
            <RadioButton
                android:id="@+id/rb_abdominales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/colorPrimary" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/colorDivider" />

        <!-- Burpees -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="B"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_avatar" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Burpees"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginStart="16dp" />
            <RadioButton
                android:id="@+id/rb_burpees"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/colorPrimary" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/colorDivider" />

        <!-- Sentadillas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="S"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_avatar" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sentadillas"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginStart="16dp" />
            <RadioButton
                android:id="@+id/rb_sentadillas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/colorPrimary" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/colorDivider" />

        <!-- Flexiones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="F"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_avatar" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Flexiones"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginStart="16dp" />
            <RadioButton
                android:id="@+id/rb_flexiones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/colorPrimary" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/colorDivider" />

    </RadioGroup>

    <!-- Campo Cantidad con controles +/- -->
    <LinearLayout
        android:id="@+id/row_cantidad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/list_exercises"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Input Cantidad editable -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_option_outline"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cantidad"
                android:textSize="12sp"
                android:textColor="@color/textSecondary" />

            <EditText
                android:id="@+id/et_cantidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="20"
                android:textSize="18sp"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:inputType="number"
                android:background="@null"
                android:padding="0dp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Botón menos -->
        <TextView
            android:id="@+id/btn_menos"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="−"
            android:textSize="24sp"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_option_outline" />

        <!-- Botón más -->
        <TextView
            android:id="@+id/btn_mas"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="24sp"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_option_outline" />

    </LinearLayout>

    <!-- Botón Guardar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_guardar"
        style="@style/TimaButtonPrimary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Guardar"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
